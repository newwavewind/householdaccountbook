{
  "framework": null,
  "installCommand": "npm ci --prefix web",
  "buildCommand": "npm run build --prefix web",
  "outputDirectory": "web/dist",
  "build": {
    "env": {
      "VITE_BASE_PATH": "/",
      "VITE_LEDGER_BACKEND": "supabase",
      "VITE_COMMUNITY_BACKEND": "supabase"
    }
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
