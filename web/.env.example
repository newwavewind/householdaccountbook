# ── 로컬 개발: SQLite + Prisma API (권장)
# web 에서 `npm run dev:full` 로 Vite + server 동시 실행
VITE_LEDGER_BACKEND=prisma
VITE_COMMUNITY_BACKEND=prisma

# 같은 가계를 쓰는 사람 모두에게 동일하게 설정 (UUID 등)
VITE_LEDGER_ID=집-가계부-내맘대로-문자열

# ── 배포 시 Supabase로 전환할 때 (예시)
# VITE_LEDGER_BACKEND=supabase
# VITE_COMMUNITY_BACKEND=supabase
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbG...

# 로컬만 장부 쓰고 커뮤니티는 목업만:
# VITE_LEDGER_BACKEND=local
# VITE_COMMUNITY_BACKEND=mock

# ── Google 로그인 (Supabase 커뮤니티 모드 전용)
# Supabase Dashboard → Authentication → Providers → Google (Client ID / Secret 은 GCP JSON)
# Google Cloud → OAuth 클라이언트 → 승인된 리디렉션 URI (Supabase 고정 콜백):
#   자동: web 폴더에서 npm run google:oauth-setup  → 클립보드 복사 + GCP 콘솔 열기
#   수동: https://<프로젝트ref>.supabase.co/auth/v1/callback  (< > 나 한글은 넣지 말 것)
# Supabase → Authentication → URL Configuration → Redirect URLs 에는 앱 콜백(쓰는 배포마다):
#   http://localhost:5173/auth/callback
#   https://web-coral-eta-s5q4upi7il.vercel.app/auth/callback  (Vercel Production 고정)
#   GitHub Pages(base가 /householdaccountbook/ 등이면):
#   https://<계정>.github.io/householdaccountbook/auth/callback
#
# 리디렉션/PKCE 대신 GIS 팝업 로그인을 쓰려면(Unable to exchange external code 우회):
# Google Cloud → OAuth 클라이언트 → 승인된 JavaScript 원본 에 http://localhost:5173 추가
# VITE_GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
# (선택) GIS FedCM. 기본은 끔. 필요 시만: VITE_GOOGLE_GSI_USE_FEDCM=true

# ── 카카오톡 공유 (달력 스티커·일정 메모)
# Kakao Developers → 내 애플리케이션 → 앱 키 → JavaScript 키
# 플랫폼 Web에 사이트 도메인(배포 URL·localhost) 등록 후 사용
# VITE_KAKAO_JAVASCRIPT_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
