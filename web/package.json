    "google:oauth-setup": "node ../scripts/open-google-oauth-setup.mjs",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.3",
    "@tiptap/extension-font-family": "^3.23.4",
